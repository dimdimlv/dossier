# ─────────────────────────────────────────────────────────────
# Dossier — environment configuration TEMPLATE
#
# This file documents the environment variables Dossier expects.
# It contains NO real values and is safe to commit (public repo).
#
# Setup:
#   1. Copy this file to `.env`        ->  cp .env.example .env
#   2. Fill in real values in `.env`
#   3. `.env` is gitignored and never committed (see ADR-001)
# ─────────────────────────────────────────────────────────────

# ── Path to the private data repository (ADR-001) ────────────
# Absolute path to your local `dossier-data` checkout.
# The application reads the inventory, application log, and writes
# generated CVs/letters under this path.
# Example (macOS): /Users/yourname/projects/dossier-data
DOSSIER_DATA_PATH=

# ── Anthropic API (used later, from the engine milestone) ────
# Your Anthropic API key. Obtain from the Anthropic console.
# Leave blank until the engine (M2+) is implemented.
ANTHROPIC_API_KEY=

# Model identifier the engine will call.
# Pinned here so the choice is explicit and easy to change.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Application behaviour (defaults are sensible) ────────────
# Default output language for generated documents (ISO 639-1).
DOSSIER_DEFAULT_LANGUAGE=en

# Days of silence after applying before a follow-up reminder fires.
DOSSIER_FOLLOWUP_DAYS=10