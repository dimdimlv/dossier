# ─────────────────────────────────────────────────────────────
# Dossier — environment configuration TEMPLATE
#
# This file documents the environment variables Dossier expects.
# It contains NO real values and is safe to commit (public repo).
#
# Setup:
#   1. Copy this file to `.env`        ->  cp .env.example .env
#   2. Fill in real values in `.env`
#   3. `.env` is gitignored and never committed (see ADR-001)
# ─────────────────────────────────────────────────────────────

# ── Path to the private data repository (ADR-001) ────────────
# Absolute path to your local `dossier-data` checkout.
# The application reads the inventory, application log, and writes
# generated CVs/letters under this path.
# Example (macOS): /Users/yourname/projects/dossier-data
# Under Docker (ADR-010) this host path also selects the directory bind-mounted
# to /data; docker-compose overrides DOSSIER_DATA_PATH to /data in the container.
DOSSIER_DATA_PATH=

# ── Anthropic API (used later, from the engine milestone) ────
# Your Anthropic API key. Obtain from the Anthropic console.
# Leave blank until the engine (M2+) is implemented.
ANTHROPIC_API_KEY=

# Model identifier the engine will call.
# Pinned here so the choice is explicit and easy to change.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── LLM provider selection ───────────────────────────────────
# Which provider the engine uses: anthropic (default) or openai.
DOSSIER_LLM_PROVIDER=anthropic

# OpenAI (only needed when DOSSIER_LLM_PROVIDER=openai).
# OPENAI_MODEL is REQUIRED in that case — pick a model that supports
# structured outputs (e.g. a current gpt-4o / gpt-4.1-class model).
OPENAI_API_KEY=
OPENAI_MODEL=

# ── Application behaviour (defaults are sensible) ────────────
# Default output language for generated documents (ISO 639-1).
DOSSIER_DEFAULT_LANGUAGE=en

# Days of silence after applying before a follow-up reminder fires.
DOSSIER_FOLLOWUP_DAYS=10

# ── Tracker database (optional) ──────────────────────────────
# The application-tracker SQLite database normally lives at
# $DOSSIER_DATA_PATH/applications/applications.db. Set this only to
# override that location (e.g. for tests or an alternate store).
# DOSSIER_DATABASE_URL=sqlite:////absolute/path/to/applications.db

# ── Monitoring (optional; M8) ────────────────────────────────
# Prometheus Pushgateway URL. Only used by
# `dossier track followups --push-metrics` (the scheduled reminder job).
# Unset means the digest never touches the network. See docs/monitoring.md.
# DOSSIER_PUSHGATEWAY_URL=http://pushgateway:9091
