# ─────────────────────────────────────────────────────────────
# Dossier — deploy stack environment TEMPLATE (deploy/.env)
#
# Copy to deploy/.env on the VPS and fill in. Safe to commit (no secrets here).
#   cp deploy/.env.example deploy/.env
# ─────────────────────────────────────────────────────────────

# Grafana admin password (change it; default "admin" is for local only).
GF_SECURITY_ADMIN_PASSWORD=admin

# ── Notes ────────────────────────────────────────────────────
# The scheduled follow-up job is configured in deploy/ofelia.ini, NOT here,
# because Ofelia reads its own INI. Set there:
#   - image:  ghcr.io/<owner>/dossier:latest
#   - volume: <host path to dossier-data>:/data
#   - schedule: cron / @daily / @every 1h
#
# The job pushes to http://pushgateway:9091 (on the `dossier` network) and needs
# no LLM API key — `dossier track followups` only reads the tracker DB.
